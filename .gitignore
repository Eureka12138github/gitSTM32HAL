# ============================================================
# PlatformIO Build Artifacts
# ============================================================
.pio/
.pio/libdeps/
.pio/build/

# ============================================================
# IDE Configuration (Keep shared settings, ignore user-specific)
# ============================================================
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/extensions.json
.vscode/tasks私人.json
.vscode/ipch/
*.code-workspace

# ============================================================
# Backup and Temporary Files
# ============================================================
/src/backup/
/include/backup/
*.bak
*.tmp
*.swp
*.swo
*~

# ============================================================
# Compiled Objects (Intermediate files)
# ============================================================
*.o
*.d
*.obj
*.lib
*.a
*.so
*.dll
*.exe

# ============================================================
# Debug Files
# ============================================================
*.log
*.dbg
*.pdb

# ============================================================
# OS Generated Files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Documentation Build Output (if applicable)
# ============================================================
docs/_build/
docs/.doctrees/

# ============================================================
# Keep important configuration files (explicitly NOT ignored)
# ============================================================
# !platformio.ini
# !.lingma/
# !README.md
